@page "/logout"
@inject IPatientAccountService AccountService
@inject NavigationManager Navigation
@inject IStringLocalizer<Logout> Localizer


<PageTitle>Logout</PageTitle>

<p>@Localizer["SignOutMessage"]</p>

@code {
    protected override async Task OnInitializedAsync()
    {
        await AccountService.LogoutAsync();
        Navigation.NavigateTo("/?msg=loggedOut", forceLoad: true);
    }
}
