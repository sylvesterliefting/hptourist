@page "/patient/medication/edit/{MedicineId:guid}"
@attribute [Authorize(Roles = "Patient")]
@rendermode InteractiveServer
@using Microsoft.EntityFrameworkCore
@using System.Security.Claims
@inject DatabaseContext DbContext
@inject AuthenticationStateProvider AuthenticationStateProvider
@inject NavigationManager Navigation

<PageTitle>Medicatie bewerken</PageTitle>

<h1>Medicatie bewerken</h1>

@if (isLoading)
{
    <p>Medicatie wordt geladen...</p>
}
else if (!string.IsNullOrWhiteSpace(errorMessage))
{
    <div class="alert alert-danger" role="alert">@errorMessage</div>
    <a href="/patient/medication" class="btn btn-secondary">Terug naar medicatie</a>
}
else
{
    <EditForm Model="medicineForm" OnValidSubmit="HandleValidSubmitAsync">
        <DataAnnotationsValidator />
        <ValidationSummary class="text-danger" />

        <div class="mb-3">
            <label for="name" class="form-label">Medicatienaam</label>
            <InputText id="name" class="form-control" @bind-Value="medicineForm.Name" />
            <ValidationMessage For="() => medicineForm.Name" class="text-danger" />
        </div>

        <div class="mb-3">
            <label for="activeSubstance" class="form-label">Werkzame stof</label>
            <InputText id="activeSubstance" class="form-control" @bind-Value="medicineForm.ActiveSubstance" />
            <ValidationMessage For="() => medicineForm.ActiveSubstance" class="text-danger" />
        </div>

        <div class="mb-3">
            <label for="atcCode" class="form-label">ATC-code (optioneel)</label>
            <InputText id="atcCode" class="form-control" @bind-Value="medicineForm.AtcCode" />
            <ValidationMessage For="() => medicineForm.AtcCode" class="text-danger" />
        </div>

        <div class="mb-3">
            <label for="pharmaceuticalForm" class="form-label">Farmaceutische vorm</label>
            <InputSelect id="pharmaceuticalForm" class="form-select" @bind-Value="medicineForm.PharmaceuticalForm">
                <option value="">Selecteer vorm...</option>
                @foreach (var form in PharmaceuticalForms)
                {
                    <option value="@form">@form</option>
                }
            </InputSelect>
            <ValidationMessage For="() => medicineForm.PharmaceuticalForm" class="text-danger" />
        </div>

        <div class="d-flex gap-2">
            <button type="submit" class="btn btn-primary">Opslaan</button>
            <a href="/patient/medication" class="btn btn-secondary">Annuleren</a>
        </div>
    </EditForm>
}

@code {
    [Parameter]
    public Guid MedicineId { get; set; }

    private static readonly string[] PharmaceuticalForms =
    [
        "Tablet",
        "Capsule",
        "Injectie",
        "Inhalator",
        "Zalf",
        "Drank",
        "Druppels",
        "Pleister",
        "Zetpil",
        "Overige"
    ];

    private MedicineForm medicineForm = new();
    private Guid? prescriptionRequestId;
    private bool isLoading = true;
    private string? errorMessage;

    protected override async Task OnInitializedAsync()
    {
        var patientId = await GetCurrentPatientIdAsync();
        if (patientId is null)
        {
            Navigation.NavigateTo("/login", forceLoad: true);
            return;
        }

        var request = await DbContext.PrescriptionRequests
            .AsNoTracking()
            .Include(r => r.Medicines)
            .Where(r => r.PatientId == patientId.Value)
            .SingleOrDefaultAsync(r => r.Medicines.Any(m => m.Id == MedicineId));

        if (request is null)
        {
            errorMessage = "Medicatie kon niet worden gevonden.";
            isLoading = false;
            return;
        }

        if (request.RequestStatus != PrescriptionRequest.Status.Pending)
        {
            errorMessage = "Alleen medicatie die nog in behandeling is kan worden aangepast.";
            isLoading = false;
            return;
        }

        var medicine = request.Medicines.Single(m => m.Id == MedicineId);
        prescriptionRequestId = request.Id;
        medicineForm = new MedicineForm
        {
            Name = medicine.Name,
            ActiveSubstance = medicine.ActiveSubstance,
            AtcCode = medicine.AtcCode,
            PharmaceuticalForm = medicine.PharmaceuticalForm,
        };
        isLoading = false;
    }

    private async Task HandleValidSubmitAsync()
    {
        var patientId = await GetCurrentPatientIdAsync();
        if (patientId is null)
        {
            Navigation.NavigateTo("/login", forceLoad: true);
            return;
        }

        var request = await DbContext.PrescriptionRequests
            .Include(r => r.Medicines)
            .Where(r => r.PatientId == patientId.Value)
            .SingleOrDefaultAsync(r => r.Id == prescriptionRequestId && r.Medicines.Any(m => m.Id == MedicineId));

        if (request is null)
        {
            errorMessage = "Medicatie kon niet worden gevonden.";
            return;
        }

        if (request.RequestStatus != PrescriptionRequest.Status.Pending)
        {
            errorMessage = "Alleen medicatie die nog in behandeling is kan worden aangepast.";
            return;
        }

        var medicine = request.Medicines.Single(m => m.Id == MedicineId);
        medicine.Name = medicineForm.Name.Trim();
        medicine.ActiveSubstance = medicineForm.ActiveSubstance.Trim();
        medicine.AtcCode = medicineForm.AtcCode?.Trim() ?? string.Empty;
        medicine.PharmaceuticalForm = medicineForm.PharmaceuticalForm.Trim();

        await DbContext.SaveChangesAsync();
        Navigation.NavigateTo("/patient/medication");
    }

    private async Task<Guid?> GetCurrentPatientIdAsync()
    {
        var authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
        var patientIdValue = authState.User.FindFirstValue("PatientId");

        return Guid.TryParse(patientIdValue, out var patientId)
            ? patientId
            : null;
    }
}
